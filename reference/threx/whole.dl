.decl normw(d:number, v:float)
normw(0, 0.85338444).
normw(1, 0.9999278).
normw(2, 0.8805004).
normw(3, 0.9358404).
normw(4, 0.85847086).
normw(5, 0.87014884).
normw(6, 0.90276146).
normw(7, 0.894265).
normw(8, 0.93200225).
normw(9, 0.90098494).
normw(10, 0.84091777).
normw(11, 0.8870165).
