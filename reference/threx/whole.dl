normw(31, 0.8630092).

.decl x0(pos:number, d:number, v:float)
x0(P, D, V) :- token(P, Id), embed_w(Id, D, V).

// ---------- layer 0 ----------
.decl ssin0(pos:number, s:float)
ssin0(P, S) :- token(P,_), S = sum (V*V) : { x0(P,_,V) }.
.decl a0(pos:number, d:number, v:float)
a0(P, D, V * (((SS/32.0)+0.000001)^(-0.5)) * G) :- x0(P,D,V), ssin0(P,SS), inln0(D,G).
.decl q0(pos:number, o:number, v:float)
q0(P,O,S) :- token(P,_), dim_d(O), S = sum (AV*WV) : { a0(P,I,AV), qw0(I,O,WV) }.
.decl k0(pos:number, o:number, v:float)
k0(P,O,S) :- token(P,_), kvout(O), S = sum (AV*WV) : { a0(P,I,AV), kw0(I,O,WV) }.
.decl v0(pos:number, o:number, v:float)
v0(P,O,S) :- token(P,_), kvout(O), S = sum (AV*WV) : { a0(P,I,AV), vw0(I,O,WV) }.
.decl qr0(pos:number, o:number, v:float)
qr0(P,O,NV) :- q0(P,O,V), qrope(O,OP,J,SG), q0(P,OP,VP), rope_cos(P,J,C), rope_sin(P,J,SN), NV = V*C + SG*VP*SN.
.decl kr0(pos:number, o:number, v:float)
kr0(P,O,NV) :- k0(P,O,V), krope(O,OP,J,SG), k0(P,OP,VP), rope_cos(P,J,C), rope_sin(P,J,SN), NV = V*C + SG*VP*SN.
.decl score0(h:number, i:number, j:number, s:float)
score0(HH,I,J, RAW*0.35355338) :- headq(HH), head_kv(HH,KV), token(I,_), token(J,_), J<=I, RAW = sum (QV*KV2) : { cidx(C), qr0(I,OQ,QV), OQ=HH*8+C, kr0(J,OK,KV2), OK=KV*8+C }.
.decl smax0(h:number, i:number, m:float)
smax0(HH,I,M) :- score0(HH,I,_,_), M = max SC : { score0(HH,I,_,SC) }.
.decl sexp0(h:number, i:number, j:number, e:float)
sexp0(HH,I,J,E) :- score0(HH,I,J,SC), smax0(HH,I,M), E = 2.718281828459045^(SC-M).
.decl sden0(h:number, i:number, z:float)
sden0(HH,I,Z) :- smax0(HH,I,_), Z = sum EE : { sexp0(HH,I,_,EE) }.
.decl prob0(h:number, i:number, j:number, p:float)
prob0(HH,I,J,P) :- sexp0(HH,I,J,E), sden0(HH,I,Z), P = E/Z.
.decl attno0(pos:number, o:number, v:float)
attno0(I,O,S) :- headq(HH), head_kv(HH,KV), cidx(C), O=HH*8+C, token(I,_), S = sum (P*VV) : { token(J,_), prob0(HH,I,J,P), v0(J,OV,VV), OV=KV*8+C }.
.decl oproj0(pos:number, d:number, v:float)
oproj0(P,D,S) :- token(P,_), dim_d(D), S = sum (AV*WV) : { attno0(P,I,AV), ow0(I,D,WV) }.
.decl xmid0(pos:number, d:number, v:float)
xmid0(P,D, XV+OV) :- x0(P,D,XV), oproj0(P,D,OV).
.decl ssm0(pos:number, s:float)
ssm0(P,S) :- token(P,_), S = sum (V*V) : { xmid0(P,_,V) }.
.decl a2_0(pos:number, d:number, v:float)
a2_0(P,D, V*(((SS/32.0)+0.000001)^(-0.5))*G) :- xmid0(P,D,V), ssm0(P,SS), postln0(D,G).
.decl gate0(pos:number, f:number, v:float)
gate0(P,F,S) :- token(P,_), ffnout(F), S = sum (AV*WV) : { a2_0(P,I,AV), gatew0(I,F,WV) }.
.decl up0(pos:number, f:number, v:float)
up0(P,F,S) :- token(P,_), ffnout(F), S = sum (AV*WV) : { a2_0(P,I,AV), upw0(I,F,WV) }.
.decl hid0(pos:number, f:number, v:float)
hid0(P,F, (G/(1.0+2.718281828459045^(0.0-G)))*U) :- gate0(P,F,G), up0(P,F,U).
.decl down0(pos:number, d:number, v:float)
down0(P,D,S) :- token(P,_), dim_d(D), S = sum (HV*WV) : { hid0(P,F,HV), downw0(F,D,WV) }.
.decl x1(pos:number, d:number, v:float)
x1(P,D, XV+DV) :- xmid0(P,D,XV), down0(P,D,DV).

// ---------- layer 1 ----------
.decl ssin1(pos:number, s:float)
ssin1(P, S) :- token(P,_), S = sum (V*V) : { x1(P,_,V) }.
.decl a1(pos:number, d:number, v:float)
a1(P, D, V * (((SS/32.0)+0.000001)^(-0.5)) * G) :- x1(P,D,V), ssin1(P,SS), inln1(D,G).
.decl q1(pos:number, o:number, v:float)
q1(P,O,S) :- token(P,_), dim_d(O), S = sum (AV*WV) : { a1(P,I,AV), qw1(I,O,WV) }.
.decl k1(pos:number, o:number, v:float)
k1(P,O,S) :- token(P,_), kvout(O), S = sum (AV*WV) : { a1(P,I,AV), kw1(I,O,WV) }.
.decl v1(pos:number, o:number, v:float)
v1(P,O,S) :- token(P,_), kvout(O), S = sum (AV*WV) : { a1(P,I,AV), vw1(I,O,WV) }.
.decl qr1(pos:number, o:number, v:float)
qr1(P,O,NV) :- q1(P,O,V), qrope(O,OP,J,SG), q1(P,OP,VP), rope_cos(P,J,C), rope_sin(P,J,SN), NV = V*C + SG*VP*SN.
.decl kr1(pos:number, o:number, v:float)
kr1(P,O,NV) :- k1(P,O,V), krope(O,OP,J,SG), k1(P,OP,VP), rope_cos(P,J,C), rope_sin(P,J,SN), NV = V*C + SG*VP*SN.
.decl score1(h:number, i:number, j:number, s:float)
score1(HH,I,J, RAW*0.35355338) :- headq(HH), head_kv(HH,KV), token(I,_), token(J,_), J<=I, RAW = sum (QV*KV2) : { cidx(C), qr1(I,OQ,QV), OQ=HH*8+C, kr1(J,OK,KV2), OK=KV*8+C }.
.decl smax1(h:number, i:number, m:float)
smax1(HH,I,M) :- score1(HH,I,_,_), M = max SC : { score1(HH,I,_,SC) }.
.decl sexp1(h:number, i:number, j:number, e:float)
sexp1(HH,I,J,E) :- score1(HH,I,J,SC), smax1(HH,I,M), E = 2.718281828459045^(SC-M).
.decl sden1(h:number, i:number, z:float)
sden1(HH,I,Z) :- smax1(HH,I,_), Z = sum EE : { sexp1(HH,I,_,EE) }.
.decl prob1(h:number, i:number, j:number, p:float)
prob1(HH,I,J,P) :- sexp1(HH,I,J,E), sden1(HH,I,Z), P = E/Z.
.decl attno1(pos:number, o:number, v:float)
attno1(I,O,S) :- headq(HH), head_kv(HH,KV), cidx(C), O=HH*8+C, token(I,_), S = sum (P*VV) : { token(J,_), prob1(HH,I,J,P), v1(J,OV,VV), OV=KV*8+C }.
.decl oproj1(pos:number, d:number, v:float)
oproj1(P,D,S) :- token(P,_), dim_d(D), S = sum (AV*WV) : { attno1(P,I,AV), ow1(I,D,WV) }.
.decl xmid1(pos:number, d:number, v:float)
xmid1(P,D, XV+OV) :- x1(P,D,XV), oproj1(P,D,OV).
.decl ssm1(pos:number, s:float)
ssm1(P,S) :- token(P,_), S = sum (V*V) : { xmid1(P,_,V) }.
.decl a2_1(pos:number, d:number, v:float)
a2_1(P,D, V*(((SS/32.0)+0.000001)^(-0.5))*G) :- xmid1(P,D,V), ssm1(P,SS), postln1(D,G).
.decl gate1(pos:number, f:number, v:float)
gate1(P,F,S) :- token(P,_), ffnout(F), S = sum (AV*WV) : { a2_1(P,I,AV), gatew1(I,F,WV) }.
.decl up1(pos:number, f:number, v:float)
up1(P,F,S) :- token(P,_), ffnout(F), S = sum (AV*WV) : { a2_1(P,I,AV), upw1(I,F,WV) }.
.decl hid1(pos:number, f:number, v:float)
hid1(P,F, (G/(1.0+2.718281828459045^(0.0-G)))*U) :- gate1(P,F,G), up1(P,F,U).
.decl down1(pos:number, d:number, v:float)
down1(P,D,S) :- token(P,_), dim_d(D), S = sum (HV*WV) : { hid1(P,F,HV), downw1(F,D,WV) }.
.decl x2(pos:number, d:number, v:float)
x2(P,D, XV+DV) :- xmid1(P,D,XV), down1(P,D,DV).

// ---------- final norm + unembed (tied) + argmax ----------
.decl ssf(pos:number, s:float)
ssf(P,S) :- token(P,_), S = sum (V*V) : { x2(P,_,V) }.
.decl xf(pos:number, d:number, v:float)
xf(P,D, V*(((SS/32.0)+0.000001)^(-0.5))*G) :- x2(P,D,V), ssf(P,SS), normw(D,G).
.decl lastpos(p:number)
lastpos(P) :- P = max Q : { token(Q,_) }.
.decl logit(v:number, s:float)
logit(V,S) :- vocab(V), lastpos(LP), S = sum (XV*EV) : { xf(LP,D,XV), embed_w(V,D,EV) }.
.decl decide(v:number)
decide(V) :- logit(V,S), S = max S2 : { logit(_,S2) }.
.output decide
.output logit
