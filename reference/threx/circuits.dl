comp0_sum(1,11).
comp0_sum(2,12).
comp0_sum(3,13).
comp0_sum(4,26).
comp0_sum(5,27).
comp0_sum(6,28).
comp0_sum(7,29).
comp0_sum(8,30).
.decl comp0(inst:number,out:number)
comp0(I,OUT) :- mp(I,P), tok(I,P,7), tok(I,Pm1,19), tok(I,Pm2,19), tok(I,Pm5,20), tok(I,Pm6,0), tok(I,Pm7,1), tok(I,Pm3,A), tok(I,Pm4,B), comp0_val(A,VA), comp0_val(B,VB), comp0_sum(VA+VB,OUT), Pm1=P-1, Pm2=P-2, Pm3=P-3, Pm4=P-4, Pm5=P-5, Pm6=P-6, Pm7=P-7.
.decl comp0_any(inst:number)
comp0_any(I) :- comp0(I,_).

.decl gate0_tab(k:number,out:number)
gate0_tab(9,16).
gate0_tab(17,1).
gate0_tab(18,1).
.decl gate0(inst:number,out:number)
gate0(I,OUT) :- mp(I,P), tok(I,Pm2,0), tok(I,Pm3,1), tok(I,P,K), gate0_tab(K,OUT), Pm2=P-2, Pm3=P-3.
.decl gate0_any(inst:number)
gate0_any(I) :- gate0(I,_).

.decl gate1_tab(k:number,out:number)
