// rosetta · circuits.dl — the model as certified next-token rules. Numbers are TOKEN IDS (model vocab).
// gramN(c1,…,c_{N-1}, t): the last N-1 tokens (c_{N-1} = most recent) predict t — gram2=bigram, gram3=trigram,…
// Routing: composed circuit (if any) wins; else the LONGEST matching n-gram wins; uncovered contexts abstain.
// Runtime: souffle only (see run.dl). Decoded view: circuits.human.md.

.decl mp(inst:number,m:number)
mp(I,M) :- M = max P : { tok(I,P,_) }.
.decl cdecide(inst:number,out:number)
.decl strength(b:number,s:number)
.decl sumthing(s:number,t:number)
.decl comp(inst:number,t:number)
.decl has_comp(inst:number)
strength(21,0).
strength(22,1).
strength(23,2).
strength(24,3).
strength(25,4).
sumthing(0,10).
sumthing(1,11).
sumthing(2,12).
sumthing(3,13).
sumthing(4,26).
sumthing(5,27).
sumthing(6,28).
sumthing(7,29).
sumthing(8,30).
comp(I,T) :- mp(I,P), tok(I,P,7), tok(I,P5,20),P5=P-5, tok(I,P4,Bi),P4=P-4, tok(I,P3,Bj),P3=P-3, strength(Bi,Si), strength(Bj,Sj), sumthing(Si+Sj,T).
has_comp(I) :- comp(I,_).
.decl gram2(c0:number,t:number)   // 2-gram: 1 context token(s) → next
.decl gram2_hit(inst:number,t:number)
.decl gram2_any(inst:number)
gram2(18,1).
gram2(1,0).
gram2(24,19).
gram2(14,19).
gram2(10,1).
gram2(26,3).
gram2(9,16).
gram2(2,1).
gram2(17,1).
gram2(11,2).
gram2_hit(I,T) :- mp(I,P), tok(I,P,C0), gram2(C0,T).
gram2_any(I) :- gram2_hit(I,_).
.decl gram3(c0:number,c1:number,t:number)   // 3-gram: 2 context token(s) → next
.decl gram3_hit(inst:number,t:number)
.decl gram3_any(inst:number)
gram3(24,19,19).
gram3(19,19,7).
gram3(7,27,1).
gram3(22,25,19).
gram3(25,19,19).
gram3(19,3,6).
gram3(23,25,19).
gram3(7,28,1).
gram3(26,3,1).
gram3(9,16,1).
gram3(6,27,2).
gram3(25,23,19).
gram3(23,19,19).
gram3(23,22,19).
gram3(22,19,19).
gram3(7,13,1).
gram3(5,7,13).
gram3(6,13,2).
gram3(4,7,12).
gram3(7,12,1).
gram3(6,29,2).
gram3(25,22,19).
gram3(8,29,3).
gram3(29,4,1).
gram3(22,23,19).
gram3(3,7,12).
gram3(6,30,2).
gram3(22,22,19).
gram3(6,28,2).
gram3(23,21,19).
gram3(21,19,19).
gram3(20,21,21).
gram3(0,16,19).
gram3(16,19,5).
gram3(19,4,6).
gram3(21,21,19).
gram3(25,25,19).
gram3(7,30,1).
gram3_hit(I,T) :- mp(I,P), tok(I,P1,C0), tok(I,P,C1), P1=P-1, gram3(C0,C1,T).
gram3_any(I) :- gram3_hit(I,_).
.decl gram4(c0:number,c1:number,c2:number,t:number)   // 4-gram: 3 context token(s) → next
.decl gram4_hit(inst:number,t:number)
.decl gram4_any(inst:number)
gram4(18,1,0,20).
gram4(27,1,0,20).
gram4(19,3,6,10).
gram4(10,1,0,20).
gram4(28,1,0,20).
gram4(3,1,0,20).
gram4(16,1,0,20).
gram4(0,4,6,30).
gram4(17,1,0,20).
gram4(13,1,0,20).
gram4(5,6,12,2).
gram4(12,1,0,20).
gram4(0,3,6,30).
gram4(4,1,0,20).
gram4(3,6,12,2).
gram4(19,4,6,12).
gram4(4,6,12,1).
gram4(30,1,0,20).
gram4_hit(I,T) :- mp(I,P), tok(I,P2,C0), tok(I,P1,C1), tok(I,P,C2), P1=P-1, P2=P-2, gram4(C0,C1,C2,T).
gram4_any(I) :- gram4_hit(I,_).
.decl gram5(c0:number,c1:number,c2:number,c3:number,t:number)   // 5-gram: 4 context token(s) → next
.decl gram5_hit(inst:number,t:number)
.decl gram5_any(inst:number)
gram5(2,1,0,4,7).
gram5(18,1,0,20,25).
gram5(27,1,0,20,25).
gram5(10,1,0,20,25).
gram5(28,1,0,5,6).
