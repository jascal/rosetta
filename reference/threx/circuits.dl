gram5(30,1,0,20,25).
gram5_hit(I,T) :- mp(I,P), tok(I,P3,C0), tok(I,P2,C1), tok(I,P1,C2), tok(I,P,C3), P1=P-1, P2=P-2, P3=P-3, gram5(C0,C1,C2,C3,T).
gram5_any(I) :- gram5_hit(I,_).
.decl gram6(c0:number,c1:number,c2:number,c3:number,c4:number,t:number)   // 6-gram: 5 context token(s) → next
.decl gram6_hit(inst:number,t:number)
.decl gram6_any(inst:number)
gram6(18,1,0,20,23,25).
gram6(27,1,0,20,22,25).
gram6(27,1,0,14,19,3).
gram6(10,1,0,20,23,24).
gram6(28,1,0,5,8,28).
gram6(5,17,1,0,20,21).
gram6(17,1,0,20,23,25).
gram6(28,1,0,20,22,25).
gram6(27,1,0,20,25,24).
gram6(16,1,0,5,6,30).
gram6(4,17,1,0,20,25).
gram6(13,1,0,5,6,28).
gram6(17,1,0,5,6,30).
gram6(13,1,0,20,25,22).
gram6(27,1,0,5,8,27).
gram6(13,1,0,14,19,5).
gram6(18,1,0,20,22,23).
gram6(13,1,0,20,23,25).
gram6(10,1,0,20,25,24).
gram6_hit(I,T) :- mp(I,P), tok(I,P4,C0), tok(I,P3,C1), tok(I,P2,C2), tok(I,P1,C3), tok(I,P,C4), P1=P-1, P2=P-2, P3=P-3, P4=P-4, gram6(C0,C1,C2,C3,C4,T).
gram6_any(I) :- gram6_hit(I,_).
.decl gram8(c0:number,c1:number,c2:number,c3:number,c4:number,c5:number,c6:number,t:number)   // 8-gram: 7 context token(s) → next
.decl gram8_hit(inst:number,t:number)
.decl gram8_any(inst:number)
gram8(4,9,16,1,0,20,22,25).
gram8(3,7,12,1,0,5,6,12).
gram8(19,7,12,1,0,5,6,27).
gram8(3,9,16,1,0,20,22,23).
gram8_hit(I,T) :- mp(I,P), tok(I,P6,C0), tok(I,P5,C1), tok(I,P4,C2), tok(I,P3,C3), tok(I,P2,C4), tok(I,P1,C5), tok(I,P,C6), P1=P-1, P2=P-2, P3=P-3, P4=P-4, P5=P-5, P6=P-6, gram8(C0,C1,C2,C3,C4,C5,C6,T).
gram8_any(I) :- gram8_hit(I,_).
cdecide(I,T) :- comp(I,T).
cdecide(I,T) :- gram2_hit(I,T), !gram3_any(I), !gram4_any(I), !gram5_any(I), !gram6_any(I), !gram8_any(I), !has_comp(I).
cdecide(I,T) :- gram3_hit(I,T), !gram4_any(I), !gram5_any(I), !gram6_any(I), !gram8_any(I), !has_comp(I).
cdecide(I,T) :- gram4_hit(I,T), !gram5_any(I), !gram6_any(I), !gram8_any(I), !has_comp(I).
cdecide(I,T) :- gram5_hit(I,T), !gram6_any(I), !gram8_any(I), !has_comp(I).
cdecide(I,T) :- gram6_hit(I,T), !gram8_any(I), !has_comp(I).
cdecide(I,T) :- gram8_hit(I,T), !has_comp(I).
