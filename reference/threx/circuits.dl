// rosetta · circuits.dl — LEARNED idioms (unsupervised, causally confirmed) + n-gram backfill. Numbers = token ids.
// model: threx.  Routing: compose > select-gate > longest n-gram > copy/induction (OOD fallback) > abstain.
// Runtime: souffle only (see run.dl). tok(inst,pos,id) is provided by the includer (run.dl / equiv.dl).

.decl mp(inst:number,m:number)
mp(I,M) :- M = max P : { tok(I,P,_) }.
.decl cdecide(inst:number,out:number)

.decl comp0_val(id:number,v:number)
comp0_val(21,0).
comp0_val(22,1).
comp0_val(23,2).
comp0_val(24,3).
comp0_val(25,4).
.decl comp0_sum(s:number,o:number)
