.decl gate1(inst:number,out:number)
gate1(I,OUT) :- mp(I,P), tok(I,P,6), tok(I,Pm2,19), tok(I,Pm4,0), tok(I,Pm5,1), tok(I,Pm3,K), gate1_tab(K,OUT), Pm2=P-2, Pm3=P-3, Pm4=P-4, Pm5=P-5.
.decl gate1_any(inst:number)
gate1_any(I) :- gate1(I,_).

