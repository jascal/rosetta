ctxlogit(I,Tk,S) :- mp(I,P), tok(I,Pm7,C0), tok(I,Pm6,C1), tok(I,Pm5,C2), tok(I,Pm4,C3), tok(I,Pm3,C4), tok(I,Pm2,C5), tok(I,Pm1,C6), tok(I,P,C7), Pm1=P-1, Pm2=P-2, Pm3=P-3, Pm4=P-4, Pm5=P-5, Pm6=P-6, Pm7=P-7, gram9d(C0,C1,C2,C3,C4,C5,C6,C7,Tk,S).

// --- softmax at the query temperature (max-shift for stability, exactly as whole.dl) ---
.decl lmax(inst:number,m:float)
lmax(I,M) :- mp(I,_), M = max S : { ctxlogit(I,_,S) }.
.decl wexp(inst:number,token:symbol,w:float)
wexp(I,Tk,W) :- ctxlogit(I,Tk,S), lmax(I,M), temp(T), W = 2.718281828459045^((S-M)/T).
.decl wz(inst:number,z:float)
wz(I,Z) :- mp(I,_), Z = sum W : { wexp(I,_,W) }.
.decl cdist(inst:number,token:symbol,prob:float)
.output cdist
cdist(I,Tk,W/Z) :- wexp(I,Tk,W), wz(I,Z).
