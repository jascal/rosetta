// rosetta · circuits.dl — the model as next-token rules carrying top-K logits (incidence); softmax(logits/T) at
// query temp. CANONICAL: we always emit T-rules; T=0 is the argmax (tropical) collapse, recovered by querying temp→0.
// Routing: longest-ngram > induction(OOD) > abstain.  tok(inst,pos,id) + temp(t) provided by the includer (run.dl). cdist(inst,token,prob) = the dist at T.

.decl mp(inst:number,m:number)
mp(I,M) :- tok(I,_,_), M = max P : { tok(I,P,_) }.
.decl ctxlogit(inst:number,token:number,s:float)

