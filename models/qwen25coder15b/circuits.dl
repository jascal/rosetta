.decl ent_present(inst:number,id:number)
ent_present(I,X) :- tok(I,_,X), entity(X).
.decl ent_count(inst:number,id:number,n:number)
ent_count(I,X,N) :- ent_present(I,X), N = count : { tok(I,P,X) }.
.decl once_ent(inst:number,id:number)
once_ent(I,X) :- ent_count(I,X,1).
.decl once_ct(inst:number,n:number)
once_ct(I,N) :- mp(I,_), N = count : { once_ent(I,X) }.
.decl once_core(inst:number,out:number)
once_core(I,OUT) :- once_ent(I,OUT), once_ct(I,1).
.decl ioi_pm(inst:number,token:number,s:float)
ioi_pm(I,OUT,0.0) :- mp(I,P), tok(I,P,311), tok(I,Pm1,7027), tok(I,Pm2,264), tok(I,Pm3,6551), tok(I,Pm5,11), tok(I,Pm6,3553), tok(I,Pm7,279), tok(I,Pm8,311), tok(I,Pm9,3937), tok(I,Pm11,323), tok(I,Pm13,4498), Pm1=P-1, Pm2=P-2, Pm3=P-3, Pm5=P-5, Pm6=P-6, Pm7=P-7, Pm8=P-8, Pm9=P-9, Pm11=P-11, Pm13=P-13, once_core(I,OUT).
.decl ioi_any(inst:number)
ioi_any(I) :- ioi_pm(I,_,_).
ctxlogit(I,Tk,S) :- ioi_pm(I,Tk,S).
.decl transitivity_pm(inst:number,token:number,s:float)
transitivity_pm(I,OUT,0.0) :- mp(I,P), tok(I,P,264), tok(I,Pm1,374), tok(I,Pm3,264), tok(I,Pm4,2055), tok(I,Pm5,13), tok(I,Pm7,264), tok(I,Pm8,374), tok(I,Pm10,362), tok(I,Pm11,13), tok(I,Pm13,264), tok(I,Pm14,374), tok(I,Pm16,32), Pm1=P-1, Pm3=P-3, Pm4=P-4, Pm5=P-5, Pm7=P-7, Pm8=P-8, Pm10=P-10, Pm11=P-11, Pm13=P-13, Pm14=P-14, Pm16=P-16, once_core(I,OUT).
.decl transitivity_any(inst:number)
transitivity_any(I) :- transitivity_pm(I,_,_).
ctxlogit(I,Tk,S) :- transitivity_pm(I,Tk,S), !ioi_any(I).
.decl modus_ponens_pm(inst:number,token:number,s:float)
modus_ponens_pm(I,OUT,0.0) :- mp(I,P), tok(I,P,374), tok(I,Pm1,419), tok(I,Pm2,2055), tok(I,Pm3,13), tok(I,Pm5,374), tok(I,Pm6,1096), tok(I,Pm7,13), tok(I,Pm9,374), tok(I,Pm10,432), tok(I,Pm11,11), tok(I,Pm13,374), tok(I,Pm14,2494), tok(I,Pm15,2679), Pm1=P-1, Pm2=P-2, Pm3=P-3, Pm5=P-5, Pm6=P-6, Pm7=P-7, Pm9=P-9, Pm10=P-10, Pm11=P-11, Pm13=P-13, Pm14=P-14, Pm15=P-15, once_core(I,OUT).
.decl modus_ponens_any(inst:number)
modus_ponens_any(I) :- modus_ponens_pm(I,_,_).
ctxlogit(I,Tk,S) :- modus_ponens_pm(I,Tk,S), !ioi_any(I), !transitivity_any(I).
.decl temporal_pm(inst:number,token:number,s:float)
temporal_pm(I,OUT,0.0) :- mp(I,P), tok(I,P,1573), tok(I,Pm1,4041), tok(I,Pm3,2055), tok(I,Pm4,13), tok(I,Pm6,1573), tok(I,Pm7,4041), tok(I,Pm9,13), tok(I,Pm11,1573), tok(I,Pm12,4041), Pm1=P-1, Pm3=P-3, Pm4=P-4, Pm6=P-6, Pm7=P-7, Pm9=P-9, Pm11=P-11, Pm12=P-12, once_core(I,OUT).
.decl temporal_any(inst:number)
temporal_any(I) :- temporal_pm(I,_,_).
ctxlogit(I,Tk,S) :- temporal_pm(I,Tk,S), !ioi_any(I), !transitivity_any(I), !modus_ponens_any(I).
.decl spatial_pm(inst:number,token:number,s:float)
spatial_pm(I,OUT,0.0) :- mp(I,P), tok(I,P,279), tok(I,Pm1,315), tok(I,Pm2,2115), tok(I,Pm3,374), tok(I,Pm5,279), tok(I,Pm6,2055), tok(I,Pm7,13), tok(I,Pm9,279), tok(I,Pm10,315), tok(I,Pm11,2115), tok(I,Pm12,374), tok(I,Pm14,576), tok(I,Pm15,13), tok(I,Pm17,279), tok(I,Pm18,315), tok(I,Pm19,2115), tok(I,Pm20,374), tok(I,Pm22,785), Pm1=P-1, Pm2=P-2, Pm3=P-3, Pm5=P-5, Pm6=P-6, Pm7=P-7, Pm9=P-9, Pm10=P-10, Pm11=P-11, Pm12=P-12, Pm14=P-14, Pm15=P-15, Pm17=P-17, Pm18=P-18, Pm19=P-19, Pm20=P-20, Pm22=P-22, once_core(I,OUT).
.decl spatial_any(inst:number)
spatial_any(I) :- spatial_pm(I,_,_).
ctxlogit(I,Tk,S) :- spatial_pm(I,Tk,S), !ioi_any(I), !transitivity_any(I), !modus_ponens_any(I), !temporal_any(I).
.decl syllogism_pm(inst:number,token:number,s:float)
syllogism_pm(I,OUT,0.0) :- mp(I,P), tok(I,P,374), tok(I,Pm2,2055), tok(I,Pm3,13), tok(I,Pm5,264), tok(I,Pm6,374), tok(I,Pm8,13), tok(I,Pm10,374), tok(I,Pm12,11510), Pm2=P-2, Pm3=P-3, Pm5=P-5, Pm6=P-6, Pm8=P-8, Pm10=P-10, Pm12=P-12, once_core(I,OUT).
.decl syllogism_any(inst:number)
syllogism_any(I) :- syllogism_pm(I,_,_).
ctxlogit(I,Tk,S) :- syllogism_pm(I,Tk,S), !ioi_any(I), !transitivity_any(I), !modus_ponens_any(I), !temporal_any(I), !spatial_any(I).

