.decl lpres(inst:number,ordv:number)
lpres(I,O) :- tok(I,_,X), lord(X,O).
.decl lmax(inst:number,ordv:number)
lmax(I,O) :- lpres(I,_), O = max OO : { lpres(I,OO) }.
.decl succ(inst:number,out:number)
succ(I,OUT) :- lmax(I,O), Om1=O-1, lpres(I,Om1), Om2=O-2, lpres(I,Om2), Op1=O+1, lat(Op1,OUT).
.decl succ_any(inst:number)
succ_any(I) :- succ(I,_).

// routing: longest n-gram > once-appearing > succession > induction > abstain
cdecide(I,T) :- gram2_hit(I,T), !gram3_any(I), !gram4_any(I), !gram5_any(I), !gram6_any(I), !gram7_any(I), !gram8_any(I), !gram9_any(I).
cdecide(I,T) :- gram3_hit(I,T), !gram4_any(I), !gram5_any(I), !gram6_any(I), !gram7_any(I), !gram8_any(I), !gram9_any(I).
cdecide(I,T) :- gram4_hit(I,T), !gram5_any(I), !gram6_any(I), !gram7_any(I), !gram8_any(I), !gram9_any(I).
cdecide(I,T) :- gram5_hit(I,T), !gram6_any(I), !gram7_any(I), !gram8_any(I), !gram9_any(I).
cdecide(I,T) :- gram6_hit(I,T), !gram7_any(I), !gram8_any(I), !gram9_any(I).
cdecide(I,T) :- gram7_hit(I,T), !gram8_any(I), !gram9_any(I).
cdecide(I,T) :- gram8_hit(I,T), !gram9_any(I).
cdecide(I,T) :- gram9_hit(I,T).
cdecide(I,T) :- once_app(I,T), !gram2_any(I), !gram3_any(I), !gram4_any(I), !gram5_any(I), !gram6_any(I), !gram7_any(I), !gram8_any(I), !gram9_any(I).
cdecide(I,T) :- succ(I,T), !gram2_any(I), !gram3_any(I), !gram4_any(I), !gram5_any(I), !gram6_any(I), !gram7_any(I), !gram8_any(I), !gram9_any(I), !once_app_any(I).
cdecide(I,T) :- ind1(I,T), !gram2_any(I), !gram3_any(I), !gram4_any(I), !gram5_any(I), !gram6_any(I), !gram7_any(I), !gram8_any(I), !gram9_any(I), !once_app_any(I), !succ_any(I).
