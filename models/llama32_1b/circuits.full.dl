gram9_hit(I,T) :- mp(I,P), tok(I,P7,C0), tok(I,P6,C1), tok(I,P5,C2), tok(I,P4,C3), tok(I,P3,C4), tok(I,P2,C5), tok(I,P1,C6), tok(I,P,C7), P1=P-1, P2=P-2, P3=P-3, P4=P-4, P5=P-5, P6=P-6, P7=P-7, gram9(C0,C1,C2,C3,C4,C5,C6,C7,T).
gram9_any(I) :- gram9_hit(I,_).

.decl ind1_pj(inst:number,j:number)
ind1_pj(I,J) :- mp(I,P), tok(I,P,X), tok(I,J,X), J<P.
.decl ind1_last(inst:number,j:number)
ind1_last(I,J) :- ind1_pj(I,_), J = max JJ : { ind1_pj(I,JJ) }.
.decl ind1(inst:number,out:number)
ind1(I,OUT) :- ind1_last(I,J), tok(I,J+1,OUT).
.decl ind1_any(inst:number)
ind1_any(I) :- ind1(I,_).

