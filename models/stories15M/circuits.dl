gram6d_any(I) :- mp(I,P), tok(I,Pm4,C0), tok(I,Pm3,C1), tok(I,Pm2,C2), tok(I,Pm1,C3), tok(I,P,C4), Pm1=P-1, Pm2=P-2, Pm3=P-3, Pm4=P-4, gram6d(C0,C1,C2,C3,C4,_,_).
ctxlogit(I,Tk,S) :- mp(I,P), tok(I,P,C0), gram2d(C0,Tk,S), !gram3d_any(I), !gram4d_any(I), !gram5d_any(I), !gram6d_any(I).
ctxlogit(I,Tk,S) :- mp(I,P), tok(I,Pm1,C0), tok(I,P,C1), Pm1=P-1, gram3d(C0,C1,Tk,S), !gram4d_any(I), !gram5d_any(I), !gram6d_any(I).
ctxlogit(I,Tk,S) :- mp(I,P), tok(I,Pm2,C0), tok(I,Pm1,C1), tok(I,P,C2), Pm1=P-1, Pm2=P-2, gram4d(C0,C1,C2,Tk,S), !gram5d_any(I), !gram6d_any(I).
ctxlogit(I,Tk,S) :- mp(I,P), tok(I,Pm3,C0), tok(I,Pm2,C1), tok(I,Pm1,C2), tok(I,P,C3), Pm1=P-1, Pm2=P-2, Pm3=P-3, gram5d(C0,C1,C2,C3,Tk,S), !gram6d_any(I).
ctxlogit(I,Tk,S) :- mp(I,P), tok(I,Pm4,C0), tok(I,Pm3,C1), tok(I,Pm2,C2), tok(I,Pm1,C3), tok(I,P,C4), Pm1=P-1, Pm2=P-2, Pm3=P-3, Pm4=P-4, gram6d(C0,C1,C2,C3,C4,Tk,S).

// --- softmax at the query temperature (max-shift for stability, exactly as whole.dl) ---
.decl lmax(inst:number,m:float)
lmax(I,M) :- mp(I,_), M = max S : { ctxlogit(I,_,S) }.
.decl wexp(inst:number,token:number,w:float)
wexp(I,Tk,W) :- ctxlogit(I,Tk,S), lmax(I,M), temp(T), W = 2.718281828459045^((S-M)/T).
.decl wz(inst:number,z:float)
wz(I,Z) :- mp(I,_), Z = sum W : { wexp(I,_,W) }.
.decl cdist(inst:number,token:number,prob:float)
cdist(I,Tk,W/Z) :- wexp(I,Tk,W), wz(I,Z).
